# Copy this file to .env and fill in your API credentials.
# .env is ignored by git.

DISCOGS_TOKEN=
LASTFM_API_KEY=

# Local app login. Change these before exposing the app on your LAN.
APP_USERNAME=admin
APP_PASSWORD=radio1190

# Optional persistent storage paths. On Debian, prefer paths outside the repo
# so git pulls or deploys cannot overwrite live cached images.
# DATABASE_URL=postgresql://radio1190:radio1190@127.0.0.1:5432/radio1190_archive
# COVER_DIR=/var/lib/radio1190-archive/covers
# ARTIST_IMAGE_DIR=/var/lib/radio1190-archive/artist-images
# ENV_PATH=/etc/radio1190-archive.env
